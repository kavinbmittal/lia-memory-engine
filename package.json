{
  "name": "@belowthesurface/lia-memory-engine",
  "version": "1.0.0",
  "description": "Lia-style context engine for OpenClaw — structured compaction, auto-flush, auto-retrieval",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "context-engine",
    "memory",
    "compaction"
  ],
  "author": "Below the Surface Studio",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@sinclair/typebox": ">=0.32.0",
    "openclaw": "*"
  },
  "dependencies": {},
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
